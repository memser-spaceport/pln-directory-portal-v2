<!-- This script is for EU geolocalisation -->
<script>
  const targetEurope = ['AL', 'AD', 'AT', 'BY', 'BE', 'BA', 'BG', 'HR', 'CY', 'CZ', 'DK', 'EE', 'FI', 'GR', 'HU', 'IS', 'IE', 'IT', 'LV', 'LI', 'LT', 'LU', 'MT', 'MD', 'MC', 'ME', 'MK', 'NO', 'PL', 'PT', 'RO', 'RS', 'SK', 'SI', 'ES', 'SE', 'CH', 'UA', 'GB', 'VA', 'SM'];
  const hasRedirected = sessionStorage.getItem('geoRedirected');
  const currentPath = window.location.pathname;

  // ONLY run the heavy fetch if we haven't redirected yet AND we aren't already on the EU path
  if (!hasRedirected && !currentPath.startsWith('/en-eu')) {
    fetch('https://ipapi.co/json/')
      .then(response => response.json())
      .then(data => {
        if (targetEurope.includes(data.country_code)) {
          sessionStorage.setItem('geoRedirected', 'true');
          let newPath = currentPath.replace('/nl-nl', '');
          window.location.href = window.location.origin + '/en-eu' + (newPath === '/' ? '' : newPath);
        }
      })
      .catch(error => console.error('Geo-redirect error:', error));
  }
</script>
