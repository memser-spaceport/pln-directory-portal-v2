        var HOME_PATHS = ['/', '/en-eu', '/nl-nl', '/fr-fr', '/de-de'];

        var p = window.location.pathname || '/';
        if (p.length > 1) p = p.replace(/\/$/, ''); // remove trailing slash except root

        var isHome = HOME_PATHS.indexOf(p) !== -1;
        document.documentElement.dataset.showEventBanner = isHome ? '1' : '0';
    })();
</script>

<style>
    #event-banner,
    .event-banner {
        position: relative;
        overflow: hidden;

        opacity: 0;
        max-height: 0;
        transform: translateY(-6px);
        pointer-events: none;

        transition: max-height 240ms ease, opacity 180ms ease, transform 240ms ease;
        will-change: max-height, opacity, transform;
    }

    html[data-show-event-banner="1"] #event-banner,
    html[data-show-event-banner="1"] .event-banner {
        opacity: 1;
        max-height: var(--event-banner-h, 80px);
        transform: translateY(0);
        pointer-events: auto;
    }

    .event-banner--dismissed {
        opacity: 0 !important;
        max-height: 0 !important;
        transform: translateY(-6px) !important;
        pointer-events: none !important;
    }

    #dismiss-banner,
    .dismiss-banner {
        position: absolute;
        top: 50%;
        right: 12px;
        transform: translateY(-50%);
        width: 32px;
        height: 32px;
        border-radius: 999px;
        display: grid;
        place-items: center;
        cursor: pointer;
        user-select: none;
        z-index: 10;

        background: rgba(255, 255, 255, 0.18);
        border: 1px solid rgba(255, 255, 255, 0.25);
        color: #fff;
    }

    @media (prefers-reduced-motion: reduce) {
        #event-banner,
        .event-banner {
            transition: none !important;
        }
    }
</style>











